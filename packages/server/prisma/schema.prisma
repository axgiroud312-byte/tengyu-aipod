datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Customer {
  id         String   @id @default(cuid())
  name       String
  phone      String   @unique
  email      String?
  wechat     String?
  notes      String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  @@map("customers")
}

enum SkillModule {
  generation
  detection
  title
}

model Skill {
  row_id            String      @id @default(cuid())
  id                String
  module            SkillModule
  category          String?
  platform          String?
  language          String?
  version           String
  enabled           Boolean     @default(true)
  system_prompt     String      @db.Text
  variables_json    String      @db.Text
  recommended_model String?
  notes             String?
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updatedAt

  @@unique([id, version])
  @@index([module, category])
  @@index([module, platform, language])
  @@map("skills")
}

model Announcement {
  id         String    @id @default(cuid())
  title      String
  content    String    @db.Text
  level      String
  audience   String?
  start_at   DateTime
  end_at     DateTime?
  created_at DateTime  @default(now())

  @@index([start_at, end_at])
  @@map("announcements")
}

model ClientVersion {
  version          String   @id
  channel          String
  platform         String
  force_upgrade    Boolean  @default(false)
  download_url_win String?
  download_url_mac String?
  changelog        String   @db.Text
  published_at     DateTime @default(now())

  @@index([channel, published_at])
  @@map("client_versions")
}

model Admin {
  id             String    @id @default(cuid())
  email          String    @unique
  password_hash  String
  name           String
  role           String
  is_active      Boolean   @default(true)
  last_login_at  DateTime?
  created_at     DateTime  @default(now())

  @@map("admins")
}

model TelemetryError {
  id             String   @id @default(cuid())
  client_version String
  module         String
  error_code     String
  error_message  String   @db.Text
  stack_trace    String?  @db.Text
  client_id      String?
  occurred_at    DateTime
  received_at    DateTime @default(now())

  @@index([error_code, occurred_at])
  @@index([module, occurred_at])
  @@map("telemetry_errors")
}
